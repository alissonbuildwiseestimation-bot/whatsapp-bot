{
  "name": "DanieWatch Whatsapp Bot",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y ffmpeg imagemagick webp && npm install",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Bot Port",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {},
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
